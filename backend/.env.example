# Django Settings
SECRET_KEY=your-secret-key-here
DEBUG=False
ALLOWED_HOSTS=your-backend.onrender.com

# Database (Supabase PostgreSQL connection string)
DATABASE_URL=postgresql://username:password@host:port/database

# CORS
CORS_ALLOWED_ORIGINS=https://your-domain.pages.dev
CSRF_TRUSTED_ORIGINS=https://your-backend.onrender.com

# Frontend URL for email verification links
FRONTEND_URL=https://your-domain.pages.dev

# Email provider configuration
EMAIL_PROVIDER=resend
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxx
RESEND_API_URL=https://api.resend.com/emails
DEFAULT_FROM_EMAIL=onboarding@resend.dev

# Brevo API (recommended when you don't own a domain)
# Set EMAIL_PROVIDER=brevo and configure the values below
BREVO_API_KEY=xkeysib-xxxxxxxxxxxxxxxx
BREVO_API_URL=https://api.brevo.com/v3/smtp/email

# SMTP fallback configuration
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@example.com
EMAIL_HOST_PASSWORD=your-app-password
EMAIL_USE_TLS=True
EMAIL_TIMEOUT=10
