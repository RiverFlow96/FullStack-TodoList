# Django Settings
SECRET_KEY=your-secret-key-here
DEBUG=False
ALLOWED_HOSTS=your-backend.onrender.com

# Database (Supabase PostgreSQL connection string)
DATABASE_URL=postgresql://username:password@aws-1-your-region.pooler.supabase.com:5432/postgres?sslmode=require

# CORS and CSRF
# Do not include trailing slash
CORS_ALLOWED_ORIGINS=https://your-production.pages.dev

# Optional: regex for Cloudflare preview URLs with changing IDs
# Example: https://abc123.fullstack-todolist.pages.dev
CORS_ALLOWED_ORIGIN_REGEXES=^https://[a-z0-9-]+\.fullstack-todolist\.pages\.dev$

CSRF_TRUSTED_ORIGINS=https://your-backend.onrender.com

# LLM provider (openai | gemini | azure)
LLM_PROVIDER=openai
LLM_TIMEOUT_SECONDS=20

# OpenAI
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4o-mini

# Gemini
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-1.5-flash

# Azure OpenAI
AZURE_OPENAI_API_KEY=your-azure-openai-api-key
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com
AZURE_OPENAI_DEPLOYMENT=your-deployment-name
AZURE_OPENAI_API_VERSION=2024-08-01-preview
